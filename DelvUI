-- Utility Functions
local function Lerp(a, b, alpha)
    return a + (b - a) * alpha
end

local function IsMouseOver(object)
    local mouse = UserInputService:GetMouseLocation()
    local pos = object.Position
    local size = object.Size
    return mouse.X >= pos.X and mouse.X <= pos.X + size.X and 
           mouse.Y >= pos.Y and mouse.Y <= pos.Y + size.Y
end

local function FormatNumber(num, decimals)
    decimals = decimals or 2
    local formatted = string.format("%." .. string.rep("f", decimals), num)
    return formatted
end

local function CreateTween(object, info, duration)
    local tween = TweenService:Create(object, duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, info)
    tween:Play()
    return tween
end

-- Window Class
local Window = {}
Window.__index = Window

function Window.new(config)
    local self = setmetatable({}, Window)
    
    self.Config = config or {}
    self.Name = self.Config.Name or "Starlight UI"
    self.Subtitle = self.Config.Subtitle or ""
    self.Position = self.Config.Position or Vector2.new(100, 100)
    self.Size = self.Config.Size or Vector2.new(500, 400)
    self.Visible = self.Config.Visible ~= false
    self.Draggable = self.Config.Draggable ~= false
    self.Closable = self.Config.Closable ~= false
    self.Theme = Themes[self.Config.Theme] or Starlight.CurrentTheme
    
    -- Create main frame
    self.Frame = Drawing.new("Square")
    self.Frame.Position = self.Position
    self.Frame.Size = self.Size
    self.Frame.Color = self.Theme.Backgrounds.Dark
    self.Frame.Thickness = 1
    self.Frame.Transparency = 0
    self.Frame.Visible = self.Visible
    
    -- Create title bar
    self.TitleBar = Drawing.new("Square")
    self.TitleBar.Size = Vector2.new(self.Size.X, 40)
    self.TitleBar.Position = Vector2.new(self.Position.X, self.Position.Y)
    self.TitleBar.Color = self.Theme.Backgrounds.Medium
    self.TitleBar.Thickness = 1
    self.TitleBar.Transparency = 0
    self.TitleBar.Visible = self.Visible
    
    -- Create title text
    self.TitleText = Drawing.new("Text")
    self.TitleText.Position = Vector2.new(self.Position.X + 50, self.Position.Y + 12)
    self.TitleText.Text = self.Name
    self.TitleText.Color = self.Theme.Foregrounds.Active
    self.TitleText.Size = Starlight.Config.TextSize + 2
    self.TitleText.Visible = self.Visible
    
    -- Create subtitle text
    self.SubtitleText = Drawing.new("Text")
    self.SubtitleText.Position = Vector2.new(self.Position.X + 50, self.Position.Y + 25)
    self.SubtitleText.Text = self.Subtitle
    self.SubtitleText.Color = self.Theme.Foregrounds.Medium
    self.SubtitleText.Size = Starlight.Config.TextSize - 2
    self.SubtitleText.Visible = self.Visible and self.Subtitle ~= ""
    
    -- Create close button
    if self.Closable then
        self.CloseButton = Drawing.new("Square")
        self.CloseButton.Size = Vector2.new(30, 30)
        self.CloseButton.Position = Vector2.new(self.Position.X + self.Size.X - 35, self.Position.Y + 5)
        self.CloseButton.Color = self.Theme.Backgrounds.Light
        self.CloseButton.Thickness = 1
        self.CloseButton.Transparency = 0
        self.CloseButton.Visible = self.Visible
        
        self.CloseText = Drawing.new("Text")
        self.CloseText.Position = Vector2.new(self.Position.X + self.Size.X - 25, self.Position.Y + 12)
        self.CloseText.Text = "×"
        self.CloseText.Color = self.Theme.Foregrounds.Medium
        self.CloseText.Size = Starlight.Config.TextSize + 4
        self.CloseText.Visible = self.Visible
    end
    
    -- Create content area
    self.Content = Drawing.new("Square")
    self.Content.Position = Vector2.new(self.Position.X, self.Position.Y + 40)
    self.Content.Size = Vector2.new(self.Size.X, self.Size.Y - 40)
    self.Content.Color = self.Theme.Backgrounds.Dark
    self.Content.Thickness = 1
    self.Content.Transparency = 0
    self.Content.Visible = self.Visible
    
    -- Tab system
    self.Tabs = {}
    self.TabSections = {}
    
    -- Dragging functionality
    if self.Draggable then
        local isDragging = false
        local dragOffset = Vector2.new(0, 0)
        
        local connection
        connection = UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 and IsMouseOver(self.TitleBar) then
                isDragging = true
                local mousePos = UserInputService:GetMouseLocation()
                dragOffset = self.Position - mousePos
            end
        end)
        
        table.insert(Starlight.Connections, connection)
        
        local moveConnection
        moveConnection = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement and isDragging then
                local mousePos = UserInputService:GetMouseLocation()
                self.Position = mousePos + dragOffset
                self:UpdatePosition()
            end
        end)
        
        table.insert(Starlight.Connections, moveConnection)
        
        local upConnection
        upConnection = UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                isDragging = false
            end
        end)
        
        table.insert(Starlight.Connections, upConnection)
    end
    
    return self
end

function Window:UpdatePosition()
    self.Frame.Position = self.Position
    self.TitleBar.Position = Vector2.new(self.Position.X, self.Position.Y)
    self.TitleText.Position = Vector2.new(self.Position.X + 50, self.Position.Y + 12)
    self.SubtitleText.Position = Vector2.new(self.Position.X + 50, self.Position.Y + 25)
    
    if self.CloseButton then
        self.CloseButton.Position = Vector2.new(self.Position.X + self.Size.X - 35, self.Position.Y + 5)
        self.CloseText.Position = Vector2.new(self.Position.X + self.Size.X - 25, self.Position.Y + 12)
    end
    
    self.Content.Position = Vector2.new(self.Position.X, self.Position.Y + 40)
    
    -- Update tab positions
    local xOffset = 10
    for _, tab in pairs(self.Tabs) do
        if tab.Button then
            tab.Button.Position = Vector2.new(self.Position.X + xOffset, self.Position.Y + 45)
            xOffset = xOffset + tab.Button.Size.X + 5
        end
    end
end

function Window:SetSize(size)
    self.Size = size
    self.Frame.Size = size
    self.TitleBar.Size = Vector2.new(size.X, 40)
    self.Content.Size = Vector2.new(size.X, size.Y - 40)
end

function Window:SetVisible(visible)
    self.Visible = visible
    self.Frame.Visible = visible
    self.TitleBar.Visible = visible
    self.TitleText.Visible = visible
    self.SubtitleText.Visible = visible and self.Subtitle ~= ""
    self.Content.Visible = visible
    
    if self.CloseButton then
        self.CloseButton.Visible = visible
        self.CloseText.Visible = visible
    end
    
    for _, tab in pairs(self.Tabs) do
        if tab.Button then
            tab.Button.Visible = visible
        end
        if tab.Text then
            tab.Text.Visible = visible
        end
    end
end

function Window:Destroy()
    if self.Frame then
        self.Frame:Remove()
        self.Frame = nil
    end
    if self.TitleBar then
        self.TitleBar:Remove()
        self.TitleBar = nil
    end
    if self.TitleText then
        self.TitleText:Remove()
        self.TitleText = nil
    end
    if self.SubtitleText then
        self.SubtitleText:Remove()
        self.SubtitleText = nil
    end
    if self.CloseButton then
        self.CloseButton:Remove()
        self.CloseButton = nil
    end
    if self.CloseText then
        self.CloseText:Remove()
        self.CloseText = nil
    end
    if self.Content then
        self.Content:Remove()
        self.Content = nil
    end
    
    -- Destroy all tabs
    for _, tab in pairs(self.Tabs) do
        if tab.Destroy then
            tab:Destroy()
        end
    end
    self.Tabs = {}
    self.TabSections = {}
end

-- Tab Class
local Tab = {}
Tab.__index = Tab

function Tab.new(config)
    local self = setmetatable({}, Tab)
    
    self.Config = config or {}
    self.Name = self.Config.Name or "Tab"
    self.Window = self.Config.Window
    self.Theme = self.Window.Theme
    self.Active = false
    
    -- Create tab button
    self.Button = Drawing.new("Square")
    self.Button.Size = Vector2.new(80, 25)
    self.Button.Position = Vector2.new(0, 0)
    self.Button.Color = self.Theme.Backgrounds.Groupbox
    self.Button.Thickness = 1
    self.Button.Transparency = 0
    self.Button.Visible = true
    
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(40, 12)
    self.Text.Text = self.Name
    self.Text.Color = self.Theme.Foregrounds.Medium
    self.Text.Size = Starlight.Config.TextSize - 2
    self.Text.Visible = true
    
    -- Tab content
    self.Groupboxes = {}
    
    return self
end

function Tab:SetActive(active)
    self.Active = active
    if active then
        self.Button.Color = self.Theme.Accents.Main
        self.Text.Color = self.Theme.Foregrounds.Active
    else
        self.Button.Color = self.Theme.Backgrounds.Groupbox
        self.Text.Color = self.Theme.Foregrounds.Medium
    end
    
    -- Show/hide groupboxes
    for _, groupbox in pairs(self.Groupboxes) do
        groupbox:SetVisible(active)
    end
end

function Tab:Destroy()
    if self.Button then
        self.Button:Remove()
        self.Button = nil
    end
    if self.Text then
        self.Text:Remove()
        self.Text = nil
    end
    
    -- Destroy all groupboxes
    for _, groupbox in pairs(self.Groupboxes) do
        if groupbox.Destroy then
            groupbox:Destroy()
        end
    end
    self.Groupboxes = {}
end

-- Groupbox Class
local Groupbox = {}
Groupbox.__index = Groupbox

function Groupbox.new(config)
    local self = setmetatable({}, Groupbox)
    
    self.Config = config or {}
    self.Name = self.Config.Name or "Groupbox"
    self.Tab = self.Config.Tab
    self.Theme = self.Tab.Window.Theme
    self.Visible = true
    
    -- Calculate position
    local yOffset = 10
    for _, existingGroupbox in pairs(self.Tab.Groupboxes) do
        yOffset = yOffset + existingGroupbox.Size.Y + 10
    end
    
    self.Position = Vector2.new(10, yOffset)
    self.Size = Vector2.new(self.Tab.Window.Size.X - 20, 30)
    
    -- Create groupbox background
    self.Background = Drawing.new("Square")
    self.Background.Position = Vector2.new(self.Tab.Window.Position.X + self.Position.X, self.Tab.Window.Position.Y + 40 + self.Position.Y)
    self.Background.Size = self.Size
    self.Background.Color = self.Theme.Backgrounds.Groupbox
    self.Background.Thickness = 1
    self.Background.Transparency = 0
    self.Background.Visible = self.Visible
    
    -- Create title
    self.Title = Drawing.new("Text")
    self.Title.Position = Vector2.new(self.Tab.Window.Position.X + self.Position.X + 10, self.Tab.Window.Position.Y + 40 + self.Position.Y + 5)
    self.Title.Text = self.Name
    self.Title.Color = self.Theme.Foregrounds.Active
    self.Title.Size = Starlight.Config.TextSize
    self.Title.Visible = self.Visible
    
    -- Elements
    self.Elements = {}
    
    return self
end

function Groupbox:AddElement(element)
    table.insert(self.Elements, element)
    
    -- Update element positions
    local yOffset = 25
    for _, existingElement in pairs(self.Elements) do
        if existingElement ~= element then
            yOffset = yOffset + existingElement.Size.Y + 5
        end
    end
    
    element.Position = Vector2.new(self.Position.X + 10, self.Position.Y + yOffset)
    element:UpdatePosition()
    
    -- Update groupbox size
    self.Size = Vector2.new(self.Tab.Window.Size.X - 20, yOffset + element.Size.Y + 10)
    self.Background.Size = self.Size
end

function Groupbox:SetVisible(visible)
    self.Visible = visible
    self.Background.Visible = visible
    self.Title.Visible = visible
    
    for _, element in pairs(self.Elements) do
        if element.SetVisible then
            element:SetVisible(visible)
        end
    end
end

function Groupbox:Destroy()
    if self.Background then
        self.Background:Remove()
        self.Background = nil
    end
    if self.Title then
        self.Title:Remove()
        self.Title = nil
    end
    
    -- Destroy all elements
    for _, element in pairs(self.Elements) do
        if element.Destroy then
            element:Destroy()
        end
    end
    self.Elements = {}
end

-- Element Classes
local Element = {}
Element.__index = Element

function Element.new(config)
    local self = setmetatable({}, Element)
    
    self.Config = config or {}
    self.Name = self.Config.Name or "Element"
    self.Type = self.Config.Type or "Button"
    self.Groupbox = self.Config.Groupbox
    self.Theme = self.Groupbox.Theme
    self.Position = self.Config.Position or Vector2.new(10, 10)
    self.Size = self.Config.Size or Vector2.new(100, 25)
    self.Callback = self.Config.Callback or function() end
    
    -- Create element based on type
    if self.Type == "Button" then
        self:CreateButton()
    elseif self.Type == "Toggle" then
        self:CreateToggle()
    elseif self.Type == "Slider" then
        self:CreateSlider()
    elseif self.Type == "Label" then
        self:CreateLabel()
    elseif self.Type == "TextBox" then
        self:CreateTextBox()
    elseif self.Type == "Dropdown" then
        self:CreateDropdown()
    end
    
    return self
end

function Element:UpdatePosition()
    local windowPos = self.Groupbox.Tab.Window.Position
    local groupboxPos = self.Groupbox.Position
    
    if self.Button then
        self.Button.Position = Vector2.new(windowPos.X + groupboxPos.X + self.Position.X, windowPos.Y + 40 + groupboxPos.Y + self.Position.Y)
    end
    if self.Text then
        self.Text.Position = Vector2.new(windowPos.X + groupboxPos.X + self.Position.X + 10, windowPos.Y + 40 + groupboxPos.Y + self.Position.Y + 5)
    end
    if self.Toggle then
        self.Toggle.Position = Vector2.new(windowPos.X + groupboxPos.X + self.Position.X, windowPos.Y + 40 + groupboxPos.Y + self.Position.Y)
    end
    if self.Indicator then
        self.Indicator.Position = Vector2.new(windowPos.X + groupboxPos.X + self.Position.X + 5, windowPos.Y + 40 + groupboxPos.Y + self.Position.Y + 2)
    end
    if self.Track then
        self.Track.Position = Vector2.new(windowPos.X + groupboxPos.X + self.Position.X, windowPos.Y + 40 + groupboxPos.Y + self.Position.Y)
    end
    if self.Handle then
        self.Handle.Position = Vector2.new(windowPos.X + groupboxPos.X + self.Position.X, windowPos.Y + 40 + groupboxPos.Y + self.Position.Y - 6)
    end
    if self.Box then
        self.Box.Position = Vector2.new(windowPos.X + groupboxPos.X + self.Position.X, windowPos.Y + 40 + groupboxPos.Y + self.Position.Y)
    end
end

function Element:CreateButton()
    self.Button = Drawing.new("Square")
    self.Button.Size = self.Size
    self.Button.Position = Vector2.new(0, 0)
    self.Button.Color = self.Theme.Backgrounds.Light
    self.Button.Thickness = 1
    self.Button.Transparency = 0
    self.Button.Visible = true
    
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(10, 5)
    self.Text.Text = self.Name
    self.Text.Color = self.Theme.Foregrounds.Active
    self.Text.Size = Starlight.Config.TextSize
    self.Text.Visible = true
    
    -- Hover effect
    local isHovering = false
    
    local hoverConnection
    hoverConnection = UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            local hovering = IsMouseOver(self.Button)
            if hovering ~= isHovering then
                isHovering = hovering
                if hovering then
                    self.Button.Color = self.Theme.Accents.Main
                else
                    self.Button.Color = self.Theme.Backgrounds.Light
                end
            end
        end
    end)
    
    table.insert(Starlight.Connections, hoverConnection)
    
    -- Click handler
    local clickConnection
    clickConnection = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and IsMouseOver(self.Button) then
            self.Button.Color = self.Theme.Accents.Brighter
            task.wait(0.1)
            self.Button.Color = self.Theme.Accents.Main
            self.Callback()
        end
    end)
    
    table.insert(Starlight.Connections, clickConnection)
end

function Element:CreateToggle()
    self.Toggle = Drawing.new("Square")
    self.Toggle.Size = Vector2.new(40, 20)
    self.Toggle.Position = Vector2.new(0, 0)
    self.Toggle.Color = self.Theme.Backgrounds.Light
    self.Toggle.Thickness = 1
    self.Toggle.Transparency = 0
    self.Toggle.Visible = true
    
    self.State = self.Config.Default ~= nil and self.Config.Default or false
    
    -- Toggle indicator
    self.Indicator = Drawing.new("Square")
    local indicatorSize = 16
    self.Indicator.Size = Vector2.new(indicatorSize, indicatorSize)
    self.Indicator.Position = Vector2.new(5, 2)
    self.Indicator.Color = self.State and self.Theme.Accents.Main or self.Theme.Backgrounds.Dark
    self.Indicator.Thickness = 1
    self.Indicator.Transparency = 0
    self.Indicator.Visible = true
    
    -- Label
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(50, 0)
    self.Text.Text = self.Name
    self.Text.Color = self.Theme.Foregrounds.Active
    self.Text.Size = Starlight.Config.TextSize
    self.Text.Visible = true
    
    -- Click handler
    local clickConnection
    clickConnection = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and IsMouseOver(self.Toggle) then
            self.State = not self.State
            self.Indicator.Color = self.State and self.Theme.Accents.Main or self.Theme.Backgrounds.Dark
            
            if self.Callback then
                self.Callback(self.State)
            end
        end
    end)
    
    table.insert(Starlight.Connections, clickConnection)
end

function Element:CreateSlider()
    self.Track = Drawing.new("Square")
    self.Track.Size = Vector2.new(self.Size.X, 4)
    self.Track.Position = Vector2.new(0, 0)
    self.Track.Color = self.Theme.Backgrounds.Light
    self.Track.Thickness = 1
    self.Track.Transparency = 0
    self.Track.Visible = true
    
    self.Handle = Drawing.new("Square")
    local handleSize = Vector2.new(16, 16)
    self.Handle.Size = handleSize
    self.Handle.Color = self.Theme.Accents.Main
    self.Handle.Thickness = 1
    self.Handle.Transparency = 0
    self.Handle.Visible = true
    
    self.Value = self.Config.Default or self.Config.Min or 0
    self.Min = self.Config.Min or 0
    self.Max = self.Config.Max or 100
    
    -- Position handle based on value
    self:UpdateHandlePosition()
    
    -- Label
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(self.Size.X + 10, -5)
    self.Text.Text = self.Name .. ": " .. FormatNumber(self.Value)
    self.Text.Color = self.Theme.Foregrounds.Active
    self.Text.Size = Starlight.Config.TextSize
    self.Text.Visible = true
    
    -- Dragging functionality
    local isDragging = false
    
    local dragConnection
    dragConnection = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and IsMouseOver(self.Handle) then
            isDragging = true
        end
    end)
    
    table.insert(Starlight.Connections, dragConnection)
    
    local moveConnection
    moveConnection = UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and isDragging then
            local mousePos = UserInputService:GetMouseLocation()
            local windowPos = self.Groupbox.Tab.Window.Position
            local groupboxPos = self.Groupbox.Position
            local relativeX = mousePos.X - (windowPos.X + groupboxPos.X + self.Position.X)
            local percent = math.clamp(relativeX / self.Size.X, 0, 1)
            self.Value = self.Min + (self.Max - self.Min) * percent
            self:UpdateHandlePosition()
            self.Text.Text = self.Name .. ": " .. FormatNumber(self.Value)
            
            if self.Callback then
                self.Callback(self.Value)
            end
        end
    end)
    
    table.insert(Starlight.Connections, moveConnection)
    
    local upConnection
    upConnection = UserInputService.InputEnded:Connect(function(input)
