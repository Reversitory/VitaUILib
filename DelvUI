function Element:CreateSlider()
    self.Track = Drawing.new("Square")
    self.Track.Position = self.Position
    self.Track.Size = Vector2.new(self.Size.X, 4)
    self.Track.Color = self.Theme.Background
    self.Track.BorderSize = 1
    self.Track.BorderColor = self.Theme.Border
    self.Track.Visible = true
    self.Track.ZIndex = 120
    
    self.Handle = Drawing.new("Square")
    local handleSize = Vector2.new(16, 16)
    self.Handle.Size = handleSize
    self.Handle.Color = self.Theme.Accent
    self.Handle.BorderSize = 1
    self.Handle.BorderColor = self.Theme.Border
    self.Handle.Visible = true
    self.Handle.ZIndex = 121
    
    self.Value = self.Config.Default or self.Config.Min or 0
    self.Min = self.Config.Min or 0
    self.Max = self.Config.Max or 100
    
    -- Position handle based on value
    self:UpdateHandlePosition()
    
    -- Label
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(self.Position.X + self.Size.X + 10, self.Position.Y + self.Size.Y/2 - 7)
    self.Text.Text = self.Name .. ": " .. FormatNumber(self.Value)
    self.Text.Color = self.Theme.Text
    self.Text.Size = Library.Config.TextSize - 2
    self.Text.Font = Library.Config.Font
    self.Text.Visible = true
    self.Text.ZIndex = 121
    
    -- Dragging functionality
    local isDragging = false
    
    local dragConnection
    dragConnection = Input.MouseButton1Down:Connect(function()
        if IsMouseOver(self.Handle) then
            isDragging = true
        end
    end)
    
    table.insert(Library.Connections, dragConnection)
    
    local moveConnection
    moveConnection = Input.MouseMoved:Connect(function()
        if isDragging then
            local mousePos = UserInputService:GetMouseLocation()
            local relativeX = mousePos.X - self.Position.X
            local percent = math.clamp(relativeX / self.Size.X, 0, 1)
            self.Value = self.Min + (self.Max - self.Min) * percent
            self:UpdateHandlePosition()
            self.Text.Text = self.Name .. ": " .. FormatNumber(self.Value)
            
            if self.Callback then
                self.Callback(self.Value)
            end
        end
    end)
    
    table.insert(Library.Connections, moveConnection)
    
    local upConnection
    upConnection = Input.MouseButton1Up:Connect(function()
        isDragging = false
    end)
    
    table.insert(Library.Connections, upConnection)
end

function Element:UpdateHandlePosition()
    local percent = (self.Value - self.Min) / (self.Max - self.Min)
    local handleX = self.Position.X + (self.Size.X - 16) * percent
    self.Handle.Position = Vector2.new(handleX, self.Position.Y - 6)
end

function Element:CreateLabel()
    self.Text = Drawing.new("Text")
    self.Text.Position = self.Position
