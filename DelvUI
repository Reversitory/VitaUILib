function Element:CreateToggle()
    self.Toggle = Drawing.new("Square")
    self.Toggle.Position = self.Position
    self.Toggle.Size = Vector2.new(40, 20)
    local toggleBgColor = (self.Theme and self.Theme.Background) or Library.Themes.Dark.Background
    self.Toggle.Color = toggleBgColor
    self.Toggle.Thickness = 1
    self.Toggle.Transparency = 0
    self.Toggle.Visible = true
    
    self.State = self.Config.Default ~= nil and self.Config.Default or false
    
    -- Toggle indicator
    self.Indicator = Drawing.new("Square")
    local indicatorSize = 16
    self.Indicator.Size = Vector2.new(indicatorSize, indicatorSize)
    self.Indicator.Position = Vector2.new(self.Position.X + 5, self.Position.Y + 2)
    local successColor = (self.Theme and self.Theme.Success) or Library.Themes.Dark.Success
    local bgColor = (self.Theme and self.Theme.Background) or Library.Themes.Dark.Background
    self.Indicator.Color = self.State and successColor or bgColor
    self.Indicator.Thickness = 1
    self.Indicator.Transparency = 0
    self.Indicator.Visible = true
    
    -- Label
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(self.Position.X + 25, self.Position.Y + self.Size.Y/2 - 7)
    self.Text.Text = self.Name
    local toggleTextColor = (self.Theme and self.Theme.Text) or Library.Themes.Dark.Text
    self.Text.Color = toggleTextColor
    self.Text.Size = Library.Config.TextSize - 2
    self.Text.Visible = true
    
    -- Click handler
    local clickConnection
    clickConnection = Input.MouseButton1Down:Connect(function()
        if IsMouseOver(self.Toggle) then
            self.State = not self.State
            self.Indicator.Color = self.State and successColor or bgColor
            
            if self.Callback then
                self.Callback(self.State)
            end
        end
    end)
    
    table.insert(Library.Connections, clickConnection)
end

function Element:CreateSlider()
    self.Track = Drawing.new("Square")
    self.Track.Position = self.Position
    self.Track.Size = Vector2.new(self.Size.X, 4)
    local trackBgColor = (self.Theme and self.Theme.Background) or Library.Themes.Dark.Background
    self.Track.Color = trackBgColor
    self.Track.Thickness = 1
    self.Track.Transparency = 0
    self.Track.Visible = true
    
    self.Handle = Drawing.new("Square")
    local handleSize = Vector2.new(16, 16)
    self.Handle.Size = handleSize
    local handleAccentColor = (self.Theme and self.Theme.Accent) or Library.Themes.Dark.Accent
    self.Handle.Color = handleAccentColor
    self.Handle.Thickness = 1
    self.Handle.Transparency = 0
    self.Handle.Visible = true
    
    self.Value = self.Config.Default or self.Config.Min or 0
    self.Min = self.Config.Min or 0
    self.Max = self.Config.Max or 100
    
    -- Position handle based on value
    self:UpdateHandlePosition()
    
    -- Label
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(self.Position.X + self.Size.X + 10, self.Position.Y + self.Size.Y/2 - 7)
    self.Text.Text = self.Name .. ": " .. FormatNumber(self.Value)
    local sliderTextColor = (self.Theme and self.Theme.Text) or Library.Themes.Dark.Text
    self.Text.Color = sliderTextColor
    self.Text.Size = Library.Config.TextSize - 2
    self.Text.Visible = true
    
    -- Dragging functionality
    local isDragging = false
    
    local dragConnection
    dragConnection = Input.MouseButton1Down:Connect(function()
        if IsMouseOver(self.Handle) then
            isDragging = true
        end
    end)
    
    table.insert(Library.Connections, dragConnection)
    
    local moveConnection
    moveConnection = Input.MouseMoved:Connect(function()
        if isDragging then
            local mousePos = UserInputService:GetMouseLocation()
            local relativeX = mousePos.X - self.Position.X
            local percent = math.clamp(relativeX / self.Size.X, 0, 1)
            self.Value = self.Min + (self.Max - self.Min) * percent
            self:UpdateHandlePosition()
            self.Text.Text = self.Name .. ": " .. FormatNumber(self.Value)
            
            if self.Callback then
                self.Callback(self.Value)
            end
        end
    end)
    
    table.insert(Library.Connections, moveConnection)
    
    local upConnection
    upConnection = Input.MouseButton1Up:Connect(function()
        isDragging = false
    end)
    
    table.insert(Library.Connections, upConnection)
end

function Element:UpdateHandlePosition()
    local percent = (self.Value - self.Min) / (self.Max - self.Min)
    local handleX = self.Position.X + (self.Size.X - 16) * percent
    self.Handle.Position = Vector2.new(handleX, self.Position.Y - 6)
end

function Element:CreateLabel()
    self.Text = Drawing.new("Text")
    self.Text.Position = self.Position
    self.Text.Text = self.Name
    local labelTextColor = (self.Theme and self.Theme.Text) or Library.Themes.Dark.Text
    self.Text.Color = labelTextColor
    self.Text.Size = Library.Config.TextSize
    self.Text.Visible = true
end

function Element:Destroy()
    if self.Button then
        self.Button:Remove()
        self.Button = nil
    end
    if self.Text then
        self.Text:Remove()
        self.Text = nil
    end
    if self.Box then
        self.Box:Remove()
        self.Box = nil
    end
    if self.Toggle then
        self.Toggle:Remove()
        self.Toggle = nil
    end
    if self.Indicator then
        self.Indicator:Remove()
        self.Indicator = nil
    end
    if self.Track then
        self.Track:Remove()
        self.Track = nil
    end
    if self.Handle then
        self.Handle:Remove()
