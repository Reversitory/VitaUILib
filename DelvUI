    end
end

-- Notification System
local Notification = {}
Notification.__index = Notification

function Notification.new(title, message, type)
    local self = setmetatable({}, Notification)
    
    self.Title = title or "Notification"
    self.Message = message or ""
    self.Type = type or "Info"
    self.Theme = Library.CurrentTheme or Library.Themes.Dark
    self.Created = tick()
    self.Duration = Library.Config.NotificationDuration
    
    -- Create notification background
    self.Background = Drawing.new("Square")
    self.Background.Size = Vector2.new(300, 80)
    self.Background.Position = Vector2.new(10, 10)
    local notifBgColor = (self.Theme and self.Theme.Background) or Library.Themes.Dark.Background
    self.Background.Color = notifBgColor
    self.Background.Thickness = 1
    self.Background.Transparency = 0
    self.Background.Visible = true
    
    -- Create title
    self.TitleText = Drawing.new("Text")
    self.TitleText.Position = Vector2.new(20, 20)
    self.TitleText.Text = self.Title
    local titleTextColor = (self.Theme and self.Theme.Text) or Library.Themes.Dark.Text
    self.TitleText.Color = titleTextColor
    self.TitleText.Size = Library.Config.TextSize + 2
    self.TitleText.Visible = true
    
    -- Create message
    self.MessageText = Drawing.new("Text")
    self.MessageText.Position = Vector2.new(20, 45)
    self.MessageText.Text = self.Message
    local messageTextColor = (self.Theme and self.Theme.TextSecondary) or Library.Themes.Dark.TextSecondary
    self.MessageText.Color = messageTextColor
    self.MessageText.Size = Library.Config.TextSize
    self.MessageText.Visible = true
    
    -- Color based on type
    if self.Type == "Success" then
        local successColor = (self.Theme and self.Theme.Success) or Library.Themes.Dark.Success
        self.Background.Color = successColor
    elseif self.Type == "Warning" then
        local warningColor = (self.Theme and self.Theme.Warning) or Library.Themes.Dark.Warning
        self.Background.Color = warningColor
    elseif self.Type == "Error" then
        local errorColor = (self.Theme and self.Theme.Error) or Library.Themes.Dark.Error
        self.Background.Color = errorColor
    else
        local accentColor = (self.Theme and self.Theme.Accent) or Library.Themes.Dark.Accent
        self.Background.Color = accentColor
    end
    
    -- Auto-remove after duration
    task.delay(self.Duration, function()
        self:Destroy()
    end)
    
    table.insert(Library.Notifications, self)
    return self
end

function Notification:Destroy()
    if self.Background then
        self.Background:Remove()
        self.Background = nil
    end
    if self.TitleText then
        self.TitleText:Remove()
        self.TitleText = nil
    end
    if self.MessageText then
        self.MessageText:Remove()
        self.MessageText = nil
    end
    
    -- Remove from notifications list
    for i, notification in pairs(Library.Notifications) do
        if notification == self then
            table.remove(Library.Notifications, i)
            break
        end
    end
end

-- Main Library Functions
function Library.new(config)
    local self = setmetatable({}, Library)
    
    self.Config = config or {}
    self.Name = self.Config.Name or "UI Library"
    self.Theme = self.Config.Theme or Library.CurrentTheme or Library.Themes.Dark
    
    -- Create main window
    self.MainWindow = Window.new({
        Title = self.Name,
        Size = self.Config.Size or Vector2.new(500, 400),
        Position = self.Config.Position or Vector2.new(100, 100),
        Draggable = true,
        Closable = false,
        Theme = self.Theme
    })
    
    return self
end

function Library:CreateTab(config)
    local tab = Tab.new({
        Name = config.Name or "Tab",
        Window = self.MainWindow,
        Theme = self.Theme
    })
    
    table.insert(self.MainWindow.Content, tab)
    
    -- Position tabs
    local xOffset = 10
    for i, tab in pairs(self.MainWindow.Content) do
        tab.Button.Position = Vector2.new(xOffset, 0)
        xOffset = xOffset + 85
    end
    
    return tab
end

function Library:CreateElement(config)
    local activeTab = self.MainWindow.Content[1] -- Default to first tab
    
    local element = Element.new({
        Name = config.Name or "Element",
        Type = config.Type or "Button",
        Tab = activeTab,
        Theme = self.Theme,
        Position = config.Position,
        Size = config.Size,
        Callback = config.Callback,
        Default = config.Default,
        Min = config.Min,
        Max = config.Max
    })
    
    table.insert(activeTab.Content, element)
    
    -- Update element positions
    local yOffset = 40
    for _, element in pairs(activeTab.Content) do
        element.Position = Vector2.new(10, yOffset)
        yOffset = yOffset + 35
    end
    
    return element
end

function Library:SetTheme(themeName)
    if Library.Themes[themeName] then
        Library.CurrentTheme = Library.Themes[themeName]
        
        -- Update all windows and elements
        for _, window in pairs(Library.Windows) do
            window.Theme = Library.CurrentTheme
            window:UpdatePosition()
            
            for _, tab in pairs(window.Content) do
                tab.Theme = Library.CurrentTheme
                
                for _, element in pairs(tab.Content) do
                    element.Theme = Library.CurrentTheme
                    -- Recreate element with new theme
                    if element.Destroy then
                        element:Destroy()
                    end
                    Element.new({
                        Name = element.Name,
                        Type = element.Type,
                        Tab = tab,
                        Theme = Library.CurrentTheme,
                        Position = element.Position,
                        Size = element.Size,
                        Callback = element.Callback,
                        Default = element.Default,
                        Min = element.Min,
                        Max = element.Max
                    })
                end
            end
        end
    end
end

function Library:Notify(title, message, type)
    return Notification.new(title, message, type)
end

function Library:Destroy()
    -- Destroy all windows
    for _, window in pairs(Library.Windows) do
        if window.Destroy then
            window:Destroy()
        end
    end
    Library.Windows = {}
    
    -- Destroy all notifications
    for _, notification in pairs(Library.Notifications) do
        if notification.Destroy then
            notification:Destroy()
        end
    end
    Library.Notifications = {}
    
    -- Disconnect all connections
    for _, connection in pairs(Library.Connections) do
        if connection.Disconnect then
            connection:Disconnect()
        end
    end
    Library.Connections = {}
end

-- Cleanup on game unload
local cleanupConnection
cleanupConnection = game.Players.PlayerRemoving:Connect(function(player)
    if player == Players.LocalPlayer then
        Library:Destroy()
    end
end)

table.insert(Library.Connections, cleanupConnection)

-- Export
return Library
