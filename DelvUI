-- Notification System
local Notification = {}
Notification.__index = Notification

function Notification.new(title, message, type)
    local self = setmetatable({}, Notification)
    
    self.Title = title or "Notification"
    self.Message = message or ""
    self.Type = type or "Info"
    self.Created = tick()
    self.Duration = Starlight.Config.NotificationDuration
    
    -- Position notifications based on existing ones
    local yOffset = 10
    for _, notification in pairs(Starlight.Notifications or {}) do
        yOffset = yOffset + 90
    end
    
    -- Create notification background
    self.Background = Drawing.new("Square")
    self.Background.Size = Vector2.new(300, 80)
    self.Background.Position = Vector2.new(10, yOffset)
    self.Background.Color = Starlight.CurrentTheme.Backgrounds.Dark
    self.Background.Thickness = 1
    self.Background.Transparency = 0
    self.Background.Visible = true
    
    -- Create title
    self.TitleText = Drawing.new("Text")
    self.TitleText.Position = Vector2.new(20, yOffset + 20)
    self.TitleText.Text = self.Title
    self.TitleText.Color = Starlight.CurrentTheme.Foregrounds.Active
    self.TitleText.Size = Starlight.Config.TextSize + 2
    self.TitleText.Visible = true
    
    -- Create message
    self.MessageText = Drawing.new("Text")
    self.MessageText.Position = Vector2.new(20, yOffset + 45)
    self.MessageText.Text = self.Message
    self.MessageText.Color = Starlight.CurrentTheme.Foregrounds.Medium
    self.MessageText.Size = Starlight.Config.TextSize
    self.MessageText.Visible = true
    
    -- Color based on type
    if self.Type == "Success" then
        self.Background.Color = Color3.fromRGB(100, 200, 100)
    elseif self.Type == "Warning" then
        self.Background.Color = Color3.fromRGB(255, 200, 100)
    elseif self.Type == "Error" then
        self.Background.Color = Color3.fromRGB(255, 100, 100)
    else
        self.Background.Color = Starlight.CurrentTheme.Accents.Main
    end
    
    -- Auto-remove after duration
    task.delay(self.Duration, function()
        self:Destroy()
    end)
    
    -- Initialize notifications table if needed
    if not Starlight.Notifications then
        Starlight.Notifications = {}
    end
    
    table.insert(Starlight.Notifications, self)
    return self
end

function Notification:Destroy()
    if self.Background then
        self.Background:Remove()
        self.Background = nil
    end
    if self.TitleText then
        self.TitleText:Remove()
        self.TitleText = nil
    end
    if self.MessageText then
        self.MessageText:Remove()
        self.MessageText = nil
    end
    
    -- Remove from notifications list
    if Starlight.Notifications then
        for i, notification in pairs(Starlight.Notifications) do
            if notification == self then
                table.remove(Starlight.Notifications, i)
                break
            end
        end
    end
end

-- Main Library Functions
function Starlight:CreateWindow(config)
    local window = Window.new(config)
    self.Window = window
    return window
end

function Starlight:CreateTab(window, name)
    local tab = Tab.new({
        Name = name,
        Window = window
    })
    
    table.insert(window.Tabs, name)
    window.TabSections[name] = {
        Tabs = {tab},
        Groupboxes = {}
    }
    
    -- Update tab positions
    window:UpdatePosition()
    
    -- Set first tab as active
    if #window.Tabs == 1 then
        tab:SetActive(true)
    end
    
    return tab
end

function Starlight:CreateGroupbox(tab, name)
    local groupbox = Groupbox.new({
        Name = name,
        Tab = tab
    })
    
    table.insert(tab.Groupboxes, groupbox)
    table.insert(tab.Window.TabSections[tab.Name].Groupboxes, groupbox)
    
    return groupbox
end

function Starlight:CreateElement(groupbox, type, name, callback, config)
    local element = Element.new({
        Type = type,
        Name = name,
        Groupbox = groupbox,
        Callback = callback,
        Size = config and config.Size,
        Default = config and config.Default,
        Min = config and config.Min,
        Max = config and config.Max
    })
    
    groupbox:AddElement(element)
    return element
end

function Starlight:Notify(title, message, type)
    return Notification.new(title, message, type)
end

function Starlight:SetTheme(themeName)
    if Themes[themeName] then
        self.CurrentTheme = Themes[themeName]
        self.Config.DefaultTheme = themeName
        
        -- Update window theme
        if self.Window then
            self.Window.Theme = self.CurrentTheme
            -- Recreate window with new theme
            local oldConfig = self.Window.Config
            self.Window:Destroy()
            self.Window = self:CreateWindow(oldConfig)
        end
    end
end

function Starlight:Destroy()
    -- Destroy all windows
    if self.Window then
        self.Window:Destroy()
        self.Window = nil
    end
    
    -- Destroy all notifications
    if self.Notifications then
        for _, notification in pairs(self.Notifications) do
            if notification.Destroy then
                notification:Destroy()
            end
        end
        self.Notifications = {}
    end
    
    -- Disconnect all connections
    for _, connection in pairs(self.Connections) do
        if connection.Disconnect then
            connection:Disconnect()
        end
    end
    self.Connections = {}
end

