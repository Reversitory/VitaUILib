-- Utility Functions
local function Lerp(a, b, alpha)
    return a + (b - a) * alpha
end

local function IsMouseOver(object)
    local mouse = UserInputService:GetMouseLocation()
    local pos = object.Position
    local size = object.Size
    return mouse.X >= pos.X and mouse.X <= pos.X + size.X and 
           mouse.Y >= pos.Y and mouse.Y <= pos.Y + size.Y
end

local function FormatNumber(num, decimals)
    decimals = decimals or 2
    local formatted = string.format("%." .. string.rep("f", decimals), num)
    return formatted
end

-- Window Class
local Window = {}
Window.__index = Window

function Window.new(config)
    local self = setmetatable({}, Window)
    
    self.Config = config or {}
    self.Position = self.Config.Position or Vector2.new(100, 100)
    self.Size = self.Config.Size or Vector2.new(400, 300)
    self.Title = self.Config.Title or "Window"
    self.Visible = self.Config.Visible ~= false
    self.Draggable = self.Config.Draggable ~= false
    self.Closable = self.Config.Closable ~= false
    self.Theme = self.Config.Theme or Library.CurrentTheme or Library.Themes.Dark
    
    -- Create main frame
    self.Frame = Drawing.new("Square")
    self.Frame.Position = self.Position
    self.Frame.Size = self.Size
    local themeColor = (self.Theme and self.Theme.Background) or Library.Themes.Dark.Background
    self.Frame.Color = themeColor
    self.Frame.Thickness = 1
    self.Frame.Transparency = 0
    self.Frame.Visible = self.Visible
    
    -- Create title bar
    self.TitleBar = Drawing.new("Square")
    self.TitleBar.Size = Vector2.new(self.Size.X, 30)
    self.TitleBar.Position = Vector2.new(self.Position.X, self.Position.Y)
    local secondaryColor = (self.Theme and self.Theme.Secondary) or Library.Themes.Dark.Secondary
    self.TitleBar.Color = secondaryColor
    self.TitleBar.Thickness = 1
    self.TitleBar.Transparency = 0
    self.TitleBar.Visible = self.Visible
    
    -- Create title text
    self.TitleText = Drawing.new("Text")
    self.TitleText.Position = Vector2.new(self.Position.X + 10, self.Position.Y + 8)
    self.TitleText.Text = self.Title
    local textColor = (self.Theme and self.Theme.Text) or Library.Themes.Dark.Text
    self.TitleText.Color = textColor
    self.TitleText.Size = Library.Config.TextSize
    self.TitleText.Visible = self.Visible
    
    -- Create close button
    if self.Closable then
        self.CloseButton = Drawing.new("Square")
        self.CloseButton.Size = Vector2.new(20, 20)
        self.CloseButton.Position = Vector2.new(self.Position.X + self.Size.X - 25, self.Position.Y + 5)
        local errorColor = (self.Theme and self.Theme.Error) or Library.Themes.Dark.Error
        self.CloseButton.Color = errorColor
        self.CloseButton.Thickness = 1
        self.CloseButton.Transparency = 0
        self.CloseButton.Visible = self.Visible
        
        self.CloseText = Drawing.new("Text")
        self.CloseText.Position = Vector2.new(self.Position.X + self.Size.X - 20, self.Position.Y + 5)
        self.CloseText.Text = "×"
        local closeTextColor = (self.Theme and self.Theme.Text) or Library.Themes.Dark.Text
        self.CloseText.Color = closeTextColor
        self.CloseText.Size = Library.Config.TextSize + 4
        self.CloseText.Visible = self.Visible
    end
    
    -- Create content area
    self.Content = Drawing.new("Square")
    self.Content.Position = Vector2.new(self.Position.X, self.Position.Y + 30)
    self.Content.Size = Vector2.new(self.Size.X, self.Size.Y - 30)
    local contentColor = (self.Theme and self.Theme.Background) or Library.Themes.Dark.Background
    self.Content.Color = contentColor
    self.Content.Thickness = 1
    self.Content.Transparency = 0
    self.Content.Visible = self.Visible
    
    -- Dragging functionality
    if self.Draggable then
        local isDragging = false
        local dragOffset = Vector2.new(0, 0)
        
        local connection
        connection = Input.MouseButton1Down:Connect(function()
            if IsMouseOver(self.Frame) then
                isDragging = true
                local mousePos = UserInputService:GetMouseLocation()
                dragOffset = self.Position - mousePos
            end
        end)
        
        table.insert(Library.Connections, connection)
        
        local moveConnection
        moveConnection = Input.MouseMoved:Connect(function()
            if isDragging then
                local mousePos = UserInputService:GetMouseLocation()
                self.Position = mousePos + dragOffset
                self:UpdatePosition()
            end
        end)
        
        table.insert(Library.Connections, moveConnection)
        
        local upConnection
        upConnection = Input.MouseButton1Up:Connect(function()
            isDragging = false
        end)
        
        table.insert(Library.Connections, upConnection)
    end
    
    table.insert(Library.Windows, self)
    return self
end

function Window:SetPosition(position)
    self.Position = position
    self:UpdatePosition()
end

function Window:UpdatePosition()
    self.Frame.Position = self.Position
    self.TitleBar.Position = Vector2.new(self.Position.X, self.Position.Y)
    self.TitleText.Position = Vector2.new(self.Position.X + 10, self.Position.Y + 8)
    
    if self.CloseButton then
        self.CloseButton.Position = Vector2.new(self.Position.X + self.Size.X - 25, self.Position.Y + 5)
        self.CloseText.Position = Vector2.new(self.Position.X + self.Size.X - 20, self.Position.Y + 5)
    end
    
    self.Content.Position = Vector2.new(self.Position.X, self.Position.Y + 30)
end

function Window:SetSize(size)
    self.Size = size
    self.Frame.Size = size
    self.TitleBar.Size = Vector2.new(size.X, 30)
    self.Content.Size = Vector2.new(size.X, size.Y - 30)
end

function Window:SetVisible(visible)
    self.Visible = visible
    self.Frame.Visible = visible
    self.TitleBar.Visible = visible
    self.TitleText.Visible = visible
    self.Content.Visible = visible
    
    if self.CloseButton then
        self.CloseButton.Visible = visible
        self.CloseText.Visible = visible
    end
end

function Window:Destroy()
    if self.Frame then
        self.Frame:Remove()
        self.Frame = nil
    end
    if self.TitleBar then
        self.TitleBar:Remove()
        self.TitleBar = nil
    end
    if self.TitleText then
        self.TitleText:Remove()
        self.TitleText = nil
    end
    if self.CloseButton then
        self.CloseButton:Remove()
        self.CloseButton = nil
    end
    if self.CloseText then
        self.CloseText:Remove()
        self.CloseText = nil
    end
    if self.Content then
        self.Content:Remove()
        self.Content = nil
    end
    
    -- Remove from windows list
    for i, window in pairs(Library.Windows) do
        if window == self then
            table.remove(Library.Windows, i)
            break
        end
    end
end

-- Tab System
local Tab = {}
Tab.__index = Tab

function Tab.new(config)
    local self = setmetatable({}, Tab)
    
    self.Config = config or {}
    self.Name = self.Config.Name or "Tab"
    self.Window = self.Config.Window
    self.Theme = self.Config.Theme or Library.CurrentTheme or Library.Themes.Dark
    
    -- Create tab button
    self.Button = Drawing.new("Square")
    self.Button.Size = Vector2.new(80, 25)
    self.Button.Position = Vector2.new(0, 0)
    local buttonColor = (self.Theme and self.Theme.Secondary) or Library.Themes.Dark.Secondary
    self.Button.Color = buttonColor
    self.Button.Thickness = 1
    self.Button.Transparency = 0
    self.Button.Visible = true
    
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(40, 12)
    self.Text.Text = self.Name
    local textTabColor = (self.Theme and self.Theme.Text) or Library.Themes.Dark.Text
    self.Text.Color = textTabColor
    self.Text.Size = Library.Config.TextSize - 2
    self.Text.Visible = true
    
    -- Tab content area
    self.Content = {}
    self.Active = false
    
    return self
end

function Tab:SetActive(active)
    self.Active = active
    if active then
        self.Button.Color = self.Theme.Accent
        self.Text.Color = Color3.fromRGB(255, 255, 255)
    else
        self.Button.Color = self.Theme.Secondary
        self.Text.Color = self.Theme.Text
    end
end

function Tab:Destroy()
    if self.Button then
        self.Button:Remove()
        self.Button = nil
    end
    if self.Text then
        self.Text:Remove()
        self.Text = nil
    end
    
    -- Destroy all content
    for _, element in pairs(self.Content) do
        if element.Destroy then
            element:Destroy()
        end
    end
    self.Content = {}
end

-- UI Elements
local Element = {}
Element.__index = Element

function Element.new(config)
    local self = setmetatable({}, Element)
    
    self.Config = config or {}
    self.Name = self.Config.Name or "Element"
    self.Type = self.Config.Type or "Button"
    self.Tab = self.Config.Tab
    self.Theme = self.Config.Theme or Library.CurrentTheme or Library.Themes.Dark
    self.Position = self.Config.Position or Vector2.new(10, 10)
    self.Size = self.Config.Size or Vector2.new(100, 25)
    self.Callback = self.Config.Callback or function() end
    
    -- Create element based on type
    if self.Type == "Button" then
        self:CreateButton()
    elseif self.Type == "TextBox" then
        self:CreateTextBox()
    elseif self.Type == "Toggle" then
        self:CreateToggle()
    elseif self.Type == "Slider" then
        self:CreateSlider()
    elseif self.Type == "Label" then
        self:CreateLabel()
    elseif self.Type == "Dropdown" then
        self:CreateDropdown()
    end
    
    return self
end

function Element:CreateButton()
    self.Button = Drawing.new("Square")
    self.Button.Position = self.Position
    self.Button.Size = self.Size
    local buttonSecColor = (self.Theme and self.Theme.Secondary) or Library.Themes.Dark.Secondary
    self.Button.Color = buttonSecColor
    self.Button.Thickness = 1
    self.Button.Transparency = 0
    self.Button.Visible = true
    
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(self.Position.X + self.Size.X/2, self.Position.Y + self.Size.Y/2)
    self.Text.Text = self.Name
    local buttonTextColor = (self.Theme and self.Theme.Text) or Library.Themes.Dark.Text
    self.Text.Color = buttonTextColor
    self.Text.Size = Library.Config.TextSize
    self.Text.Visible = true
    
    -- Hover effect
    local isHovering = false
    
    local hoverConnection
    hoverConnection = Input.MouseMoved:Connect(function()
        local hovering = IsMouseOver(self.Button)
        if hovering ~= isHovering then
            isHovering = hovering
            if hovering then
                self.Button.Color = Lerp(self.Theme.Secondary, self.Theme.Accent, 0.3)
            else
                self.Button.Color = self.Theme.Secondary
            end
        end
    end)
    
    table.insert(Library.Connections, hoverConnection)
    
    -- Click handler
    local clickConnection
    clickConnection = Input.MouseButton1Down:Connect(function()
        if IsMouseOver(self.Button) then
            self.Button.Color = self.Theme.Accent
            task.wait(0.1)
            self.Button.Color = self.Theme.Secondary
            self.Callback()
        end
    end)
    
    table.insert(Library.Connections, clickConnection)
end

