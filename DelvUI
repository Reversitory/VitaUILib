-- Utility Functions
local function CreateTween(object, info, duration)
    local tween = TweenService:Create(object, duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, info)
    tween:Play()
    return tween
end

local function Lerp(a, b, alpha)
    return a + (b - a) * alpha
end

local function IsMouseOver(object)
    local mouse = UserInputService:GetMouseLocation()
    local pos = object.AbsolutePosition
    local size = object.AbsoluteSize
    return mouse.X >= pos.X and mouse.X <= pos.X + size.X and 
           mouse.Y >= pos.Y and mouse.Y <= pos.Y + size.Y
end

local function FormatNumber(num, decimals)
    decimals = decimals or 2
    local formatted = string.format("%." .. string.rep("f", decimals), num)
    return formatted
end

-- Window Class
local Window = {}
Window.__index = Window

function Window.new(config)
    local self = setmetatable({}, Window)
    
    self.Config = config or {}
    self.Position = self.Config.Position or Vector2.new(100, 100)
    self.Size = self.Config.Size or Vector2.new(400, 300)
    self.Title = self.Config.Title or "Window"
    self.Visible = self.Config.Visible ~= false
    self.Draggable = self.Config.Draggable ~= false
    self.Closable = self.Config.Closable ~= false
    self.Theme = self.Config.Theme or Library.CurrentTheme
    
    -- Create main frame
    self.Frame = Drawing.new("Square")
    self.Frame.Position = self.Position
    self.Frame.Size = self.Size
    self.Frame.Color = self.Theme.Background
    self.Frame.BorderSize = 1
    self.Frame.BorderColor = self.Theme.Border
    self.Frame.Visible = self.Visible
    self.Frame.ZIndex = 100
    
    -- Create title bar
    self.TitleBar = Drawing.new("Square")
    self.TitleBar.Size = Vector2.new(self.Size.X, 30)
    self.TitleBar.Position = Vector2.new(self.Position.X, self.Position.Y)
    self.TitleBar.Color = self.Theme.Secondary
    self.TitleBar.BorderSize = 1
    self.TitleBar.BorderColor = self.Theme.Border
    self.TitleBar.Visible = self.Visible
    self.TitleBar.ZIndex = 101
    
    -- Create title text
    self.TitleText = Drawing.new("Text")
    self.TitleText.Position = Vector2.new(self.Position.X + 10, self.Position.Y + 8)
    self.TitleText.Text = self.Title
    self.TitleText.Color = self.Theme.Text
    self.TitleText.Size = Library.Config.TextSize
    self.TitleText.Font = Library.Config.Font
    self.TitleText.Visible = self.Visible
    self.TitleText.ZIndex = 102
    
    -- Create close button
    if self.Closable then
        self.CloseButton = Drawing.new("Square")
        self.CloseButton.Size = Vector2.new(20, 20)
        self.CloseButton.Position = Vector2.new(self.Position.X + self.Size.X - 25, self.Position.Y + 5)
        self.CloseButton.Color = self.Theme.Error
        self.CloseButton.BorderSize = 1
        self.CloseButton.BorderColor = self.Theme.Border
        self.CloseButton.Visible = self.Visible
        self.CloseButton.ZIndex = 103
        
        self.CloseText = Drawing.new("Text")
        self.CloseText.Position = Vector2.new(self.Position.X + self.Size.X - 20, self.Position.Y + 5)
        self.CloseText.Text = "×"
        self.CloseText.Color = self.Theme.Text
        self.CloseText.Size = Library.Config.TextSize + 4
        self.CloseText.Font = Library.Config.Font
        self.CloseText.Visible = self.Visible
        self.CloseText.ZIndex = 104
        self.CloseText.Center = true
    end
    
    -- Create content area
    self.Content = Drawing.new("Square")
    self.Content.Position = Vector2.new(self.Position.X, self.Position.Y + 30)
    self.Content.Size = Vector2.new(self.Size.X, self.Size.Y - 30)
    self.Content.Color = self.Theme.Background
    self.Content.BorderSize = 1
    self.Content.BorderColor = self.Theme.Border
    self.Content.Visible = self.Visible
    self.Content.ZIndex = 99
    
    -- Dragging functionality
    if self.Draggable then
        local isDragging = false
        local dragOffset = Vector2.new(0, 0)
        
        local connection
        connection = Input.MouseButton1Down:Connect(function()
            if IsMouseOver(self.Frame) then
                isDragging = true
                local mousePos = UserInputService:GetMouseLocation()
                dragOffset = self.Position - mousePos
            end
        end)
        
        table.insert(Library.Connections, connection)
        
        local moveConnection
        moveConnection = Input.MouseMoved:Connect(function()
            if isDragging then
                local mousePos = UserInputService:GetMouseLocation()
                self.Position = mousePos + dragOffset
                self:UpdatePosition()
            end
        end)
        
        table.insert(Library.Connections, moveConnection)
        
        local upConnection
        upConnection = Input.MouseButton1Up:Connect(function()
            isDragging = false
        end)
        
        table.insert(Library.Connections, upConnection)
    end
    
    table.insert(Library.Windows, self)
    return self
end

function Window:SetPosition(position)
    self.Position = position
    self:UpdatePosition()
end

function Window:UpdatePosition()
    self.Frame.Position = self.Position
    self.TitleBar.Position = Vector2.new(self.Position.X, self.Position.Y)
    self.TitleText.Position = Vector2.new(self.Position.X + 10, self.Position.Y + 8)
    
    if self.CloseButton then
        self.CloseButton.Position = Vector2.new(self.Position.X + self.Size.X - 25, self.Position.Y + 5)
        self.CloseText.Position = Vector2.new(self.Position.X + self.Size.X - 20, self.Position.Y + 5)
    end
    
    self.Content.Position = Vector2.new(self.Position.X, self.Position.Y + 30)
end

function Window:SetSize(size)
    self.Size = size
    self.Frame.Size = size
    self.TitleBar.Size = Vector2.new(size.X, 30)
    self.Content.Size = Vector2.new(size.X, size.Y - 30)
end

function Window:SetVisible(visible)
    self.Visible = visible
    self.Frame.Visible = visible
    self.TitleBar.Visible = visible
    self.TitleText.Visible = visible
    self.Content.Visible = visible
    
    if self.CloseButton then
        self.CloseButton.Visible = visible
        self.CloseText.Visible = visible
    end
end

function Window:Destroy()
    if self.Frame then
        self.Frame:Remove()
        self.Frame = nil
    end
    if self.TitleBar then
        self.TitleBar:Remove()
        self.TitleBar = nil
    end
    if self.TitleText then
        self.TitleText:Remove()
        self.TitleText = nil
    end
    if self.CloseButton then
        self.CloseButton:Remove()
        self.CloseButton = nil
    end
    if self.CloseText then
        self.CloseText:Remove()
        self.CloseText = nil
    end
    if self.Content then
        self.Content:Remove()
        self.Content = nil
    end
    
    -- Remove from windows list
    for i, window in pairs(Library.Windows) do
        if window == self then
            table.remove(Library.Windows, i)
            break
        end
    end
end

