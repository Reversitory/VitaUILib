local Element = {}
Element.__index = Element

function Element.new(config)
    local self = setmetatable({}, Element)
    
    self.Config = config or {}
    self.Name = self.Config.Name or "Element"
    self.Type = self.Config.Type or "Button"
    self.Tab = self.Config.Tab
    self.Theme = self.Config.Theme or Library.CurrentTheme
    self.Position = self.Config.Position or Vector2.new(10, 10)
    self.Size = self.Config.Size or Vector2.new(100, 25)
    self.Callback = self.Config.Callback or function() end
    
    -- Create element based on type
    if self.Type == "Button" then
        self:CreateButton()
    elseif self.Type == "TextBox" then
        self:CreateTextBox()
    elseif self.Type == "Toggle" then
        self:CreateToggle()
    elseif self.Type == "Slider" then
        self:CreateSlider()
    elseif self.Type == "Label" then
        self:CreateLabel()
    elseif self.Type == "Dropdown" then
        self:CreateDropdown()
    end
    
    return self
end

function Element:CreateButton()
    self.Button = Drawing.new("Square")
    self.Button.Position = self.Position
    self.Button.Size = self.Size
    self.Button.Color = self.Theme.Secondary
    self.Button.BorderSize = 1
    self.Button.BorderColor = self.Theme.Accent
    self.Button.Visible = true
    self.Button.ZIndex = 120
    
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(self.Position.X + self.Size.X/2, self.Position.Y + self.Size.Y/2)
    self.Text.Text = self.Name
    self.Text.Color = self.Theme.Text
    self.Text.Size = Library.Config.TextSize
    self.Text.Font = Library.Config.Font
    self.Text.Visible = true
    self.Text.ZIndex = 121
    self.Text.Center = true
    
    -- Hover effect
    local isHovering = false
    
    local hoverConnection
    hoverConnection = Input.MouseMoved:Connect(function()
        local hovering = IsMouseOver(self.Button)
        if hovering ~= isHovering then
            isHovering = hovering
            if hovering then
                self.Button.Color = Lerp(self.Theme.Secondary, self.Theme.Accent, 0.3)
            else
                self.Button.Color = self.Theme.Secondary
            end
        end
    end)
    
    table.insert(Library.Connections, hoverConnection)
    
    -- Click handler
    local clickConnection
    clickConnection = Input.MouseButton1Down:Connect(function()
        if IsMouseOver(self.Button) then
            self.Button.Color = self.Theme.Accent
            CreateTween(self.Button, {Color = self.Theme.Secondary}, 0.1)
            self.Callback()
        end
    end)
    
    table.insert(Library.Connections, clickConnection)
end

