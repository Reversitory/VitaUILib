function Tab.new(config)
    local self = setmetatable({}, Tab)
    
    self.Config = config or {}
    self.Name = self.Config.Name or "Tab"
    self.Window = self.Config.Window
    self.Theme = self.Config.Theme or Library.CurrentTheme
    
    -- Create tab button
    self.Button = Drawing.new("Square")
    self.Button.Size = Vector2.new(80, 25)
    self.Button.Position = Vector2.new(0, 0)
    self.Button.Color = self.Theme.Secondary
    self.Button.BorderSize = 1
    self.Button.BorderColor = self.Theme.Accent
    self.Button.Visible = true
    self.Button.ZIndex = 110
    
    self.Text = Drawing.new("Text")
    self.Text.Position = Vector2.new(40, 12)
    self.Text.Text = self.Name
    self.Text.Color = self.Theme.Text
    self.Text.Size = Library.Config.TextSize - 2
    self.Text.Font = Library.Config.Font
    self.Text.Visible = true
    self.Text.ZIndex = 111
    self.Text.Center = true
    
    -- Tab content area
    self.Content = {}
    self.Active = false
    
    return self
end

function Tab:SetActive(active)
    self.Active = active
    if active then
        self.Button.Color = self.Theme.Accent
        self.Text.Color = Color3.fromRGB(255, 255, 255)
    else
        self.Button.Color = self.Theme.Secondary
        self.Text.Color = self.Theme.Text
    end
end

function Tab:Destroy()
    if self.Button then
        self.Button:Remove()
        self.Button = nil
    end
    if self.Text then
        self.Text:Remove()
        self.Text = nil
    end
    
    -- Destroy all content
    for _, element in pairs(self.Content) do
        if element.Destroy then
            element:Destroy()
        end
    end
    self.Content = {}
end

